import socket
import threading
import random
import time

# Конфигурация
HOST = '0.0.0.0'      # Слушать на всех интерфейсах
PORT = 4444
ROUNDS = 5
TIMEOUT = 3.0         # Таймаут на один ответ в секундах
FLAG = "FLAG{s0ck3t_m4th_m4st3r}"

def handle_client(conn, addr):
    print(f"[+] Новый клиент: {addr}")
    conn.settimeout(TIMEOUT)  # Устанавливаем таймаут на операции recv

    try:
        # Приветствие
        conn.sendall(b"Welcome to Math Marathon!\n")
        conn.sendall(f"Solve {ROUNDS} expressions. You have {TIMEOUT} seconds per answer.\n".encode())
        conn.sendall(b"Good luck!\n\n")

        for round_num in range(1, ROUNDS + 1):
            # Генерируем случайное выражение
            a = random.randint(1, 100)
            b = random.randint(1, 100)
            op = random.choice(['+', '-', '*', '//'])  # целочисленное деление

            # Вычисляем правильный ответ (безопасно, т.к. выражение формируем сами)
            expression = f"{a} {op} {b}"
            correct_answer = eval(expression)  # для учебных целей OK

            # Отправляем задание
            prompt = f"Round {round_num}/{ROUNDS}: {expression} = ?\n"
            conn.sendall(prompt.encode())

            # Ждём ответ от клиента
            data = conn.recv(1024).decode().strip()
            if not data:
            	return
                break

            # Проверяем ответ
            try:
                user_answer = int(data)
            except ValueError:
                conn.sendall(b"Error: answer must be an integer.\n")
                return
                break

            if user_answer == correct_answer:
                conn.sendall(b"Correct!\n")
            else:
                conn.sendall(f"Wrong! Expected {correct_answer}.\n".encode())
                conn.close()
                return

        # Если все раунды пройдены успешно
        conn.sendall(f"\nCongratulations! Here is your flag: {FLAG}\n".encode())

    except socket.timeout:
        conn.sendall(b"\n[!] Timeout! You were too slow.\n")
    except Exception as e:
        print(f"[-] Ошибка с клиентом {addr}: {e}")
    finally:
        conn.close()
        print(f"[-] Клиент {addr} отключён")

def start_server():
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((HOST, PORT))
    server.listen(5)
    print(f"[*] Math Marathon сервер запущен на {HOST}:{PORT}")

    while True:
        conn, addr = server.accept()
        thread = threading.Thread(target=handle_client, args=(conn, addr))
        thread.start()

if __name__ == "__main__":
    start_server()